# --- Supabase (project settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- OpenAI (chat + embeddings) ---
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Cohere (rerank, optional but used when present) ---
COHERE_API_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Seeded demo accounts (used by `npm run seed`) ---
SEED_USER_A_EMAIL=alice@demo.local
SEED_USER_A_PASSWORD=demo-password-A!
SEED_USER_B_EMAIL=bob@demo.local
SEED_USER_B_PASSWORD=demo-password-B!
